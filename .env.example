# Variant Launch SDK key — enables AR on iOS (iPhone/iPad) via an App Clip
# WebXR polyfill. Create a project at https://launch.variant3d.com to get one.
# Locally: copy this file to .env.local and fill in the key.
# On Vercel: add it under Project Settings -> Environment Variables.
# Leave unset to skip iOS AR (iOS visitors get the 2D browser view).
VITE_VARIANT_LAUNCH_KEY=
